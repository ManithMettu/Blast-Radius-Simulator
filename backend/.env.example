# Server
NODE_ENV=development
PORT=4000
# Comma-separated allowed frontend origins for CORS
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL) — must start with postgres:// or postgresql://
# Aiven example (no quotes in Netlify UI):
# postgres://USER:PASSWORD@HOST:PORT/defaultdb?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/blast_radius?schema=public"

# Netlify: set DATABASE_URL, NODE_ENV=production, and FRONTEND_URL in
# Site settings → Environment variables. Enable "Builds" + "Functions" scopes.
