{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "Dependency Blast Radius Simulator API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphlib": "^2.1.8",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "prisma": "^6.8.0",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/graphlib": "^2.1.12",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.9.3",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
