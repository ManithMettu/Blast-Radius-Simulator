{
  "name": "blast-radius-simulator",
  "private": true,
  "scripts": {
    "dev:api": "npm --prefix backend run dev",
    "dev:web": "pnpm --dir frontend dev",
    "build": "npm --prefix backend run build && pnpm --dir frontend build",
    "test": "npm --prefix backend test",
    "db:up": "docker compose up -d postgres",
    "db:migrate": "npm --prefix backend run db:deploy",
    "db:seed": "npm --prefix backend run db:seed",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  }
}
